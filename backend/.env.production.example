APP_NAME=AlcoTracker
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.alcotracker.ru

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=alcotracker
DB_USERNAME=laravel
DB_PASSWORD=CHANGE_ME_strong_password_32chars

# Sanctum / сессии (замени домен на свой)
SANCTUM_STATEFUL_DOMAINS=alcotracker.ru
SESSION_DOMAIN=.alcotracker.ru
SESSION_SECURE_COOKIE=true
SESSION_DRIVER=database
SESSION_LIFETIME=120

# CORS (замени домен на свой)
CORS_ALLOWED_ORIGINS=https://alcotracker.ru

# Почта — Brevo бесплатно до 300 писем/день
# Или MAIL_MAILER=log если сброс пароля не нужен
MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your_brevo_smtp_key
MAIL_FROM_ADDRESS=noreply@alcotracker.ru
MAIL_FROM_NAME="${APP_NAME}"

CACHE_STORE=database
QUEUE_CONNECTION=database
